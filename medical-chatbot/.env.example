# Health Atlas Chatbot Configuration
# Copy this to .env and fill in your values

# === GitHub Models (Free to start) ===
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Chat model to use (GitHub Models)
CHAT_ENDPOINT=https://models.github.ai/inference
CHAT_MODEL=openai/gpt-4.1

# Alternative: Azure OpenAI
# AZURE_OPENAI_API_KEY=your_azure_key_here
# CHAT_ENDPOINT=https://your-resource.openai.azure.com
# CHAT_MODEL=gpt-4

# === Health Atlas Backend API ===
HEALTHATLAS_API_URL=http://localhost:8080/api

# === Server Configuration ===
# Port for the chatbot HTTP server
CHATBOT_PORT=8087

# CORS Origins (comma-separated, for production deployment)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# === Optional: Authentication ===
# Add authentication tokens for secure API access
# API_AUTH_TOKEN=your_backend_auth_token
