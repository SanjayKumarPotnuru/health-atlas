spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/healthatlas
    username: postgres
    password: your_postgres_password_here
    driver-class-name: org.postgresql.Driver
  
  jpa:
    show-sql: true
    properties:
      hibernate:
        format_sql: true

logging:
  level:
    com.healthatlas: DEBUG
    org.springframework.security: DEBUG
